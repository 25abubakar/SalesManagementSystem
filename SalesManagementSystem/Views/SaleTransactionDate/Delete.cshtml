@model SalesManagementSystem.Models.SaleTransactionDate

<div class="container mt-5">

    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            Delete Confirmation
        </div>

        <div class="card-body">

            <h5>Are you sure you want to delete this record?</h5>

            <ul class="list-group mb-3">
                <li class="list-group-item">
                    Transaction: @Model.Id
                </li>
                <li class="list-group-item">
                    Date Label: @Model.SaleDate?.DateLabel
                </li>
                <li class="list-group-item">
                    Date: @Model.Date.ToShortDateString()
                </li>
            </ul>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="SaleAcctId" />

                <button class="btn btn-danger">Delete</button>
                <a asp-action="Index" asp-route-saleId="@Model.SaleAcctId" class="btn btn-secondary">Cancel</a>
            </form>

        </div>
    </div>

</div>