@model SalesManagementSystem.Models.SaleTransactionDate

@{
    ViewData["Title"] = "Delete Sale Transaction Date";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">🗑️ Delete Confirmation</h4>
        </div>

        <div class="card-body">

            <h5 class="text-danger mb-4">
                Are you sure you want to delete this record?
            </h5>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Transaction ID</div>
                <div class="col-md-8">@Model.SaleTransId</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Sale Account</div>
                <div class="col-md-8">
                    Order: @(Model.SaleAcct?.OrderID ?? "No OrderID")
                    (ID: @Model.SaleAcctId)
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Sale Date Ref</div>
                <div class="col-md-8">
                    SaleDate #@Model.SaleDateId
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4 fw-bold">Transaction Date</div>
                <div class="col-md-8">
                    @Model.Date?.ToString("dd-MMM-yyyy")
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="SaleTransId" />

                <button class="btn btn-danger px-4">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
            </form>

        </div>
    </div>
</div>