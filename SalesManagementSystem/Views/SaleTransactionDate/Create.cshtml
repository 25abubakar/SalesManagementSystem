@model SalesManagementSystem.Models.SaleTransactionDate
@{
    long? saleId = Model.SaleAcctId > 0 ? Model.SaleAcctId : null;
}

<div class="container mt-4">

    <h3 class="mb-4 text-primary">📅 Assign Sale Transaction Date</h3>

    <div class="card shadow-sm p-4">

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Sale Transaction</label>
                <select asp-for="SaleAcctId"
                        asp-items="ViewBag.SaleTransactions"
                        class="form-select">
                    <option value="">-- Select Transaction --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Date Label</label>
                <select asp-for="DateLabelId"
                        asp-items="ViewBag.DateLabels"
                        class="form-select">
                    <option value="">-- Select Label --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Date</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" asp-route-saleId="@saleId" class="btn btn-secondary">Back</a>
                <button type="submit" class="btn btn-success" id="saveTxnDateButton">Save</button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.querySelector('form');
            form.addEventListener('submit', () => {
                const button = document.getElementById('saveTxnDateButton');
                if (button) {
                    button.disabled = true;
                    button.textContent = 'Saving...';
                }
            });
        })();
    </script>
}