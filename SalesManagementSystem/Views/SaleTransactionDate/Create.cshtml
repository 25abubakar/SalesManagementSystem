@model SalesManagementSystem.Models.SaleTransactionVM

<style>
    body {
        background: #f5f7fb;
    }

    .page-wrapper {
        max-width: 900px;
        margin: auto;
    }

    .header-card {
        background: linear-gradient(135deg,#0d6efd,#4e73df);
        color: white;
        padding: 25px;
        border-radius: 16px;
        text-align: center;
        margin-bottom: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 8px 22px rgba(0,0,0,0.08);
    }

    .form-group label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
    }

    .btn-primary {
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
    }

    .side-image {
        width: 100%;
        border-radius: 14px;
        margin-bottom: 15px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }

    .row-flex {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .left {
        flex: 1;
        min-width: 250px;
    }

    .right {
        flex: 2;
        min-width: 300px;
    }
</style>

<div class="page-wrapper mt-4">

    <!-- HEADER -->
    <div class="header-card">
        <h2>📅 Assign Sale Transaction Date</h2>
        <p class="mb-0">Link sales with transaction timeline</p>
    </div>

    <div class="row-flex">

        <!-- IMAGE SIDE -->
        <div class="left">
            <img src="https://cdn-icons-png.flaticon.com/512/2838/2838912.png"
                 class="side-image" alt="Transaction">

            <img src="https://cdn-icons-png.flaticon.com/512/2920/2920277.png"
                 class="side-image" alt="Calendar">
        </div>

        <!-- FORM SIDE -->
        <div class="right">

            <div class="form-card">

                <form asp-action="Create">

                    <div class="form-group mb-3">
                        <label>Sale Account</label>
                        <select asp-for="SaleAcctId" asp-items="Model.SaleAcctList" class="form-control">
                            <option value="">-- Select Sale Account --</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label>Sale Date Record</label>
                        <select asp-for="SaleDateId" asp-items="Model.SaleDateList" class="form-control">
                            <option value="">-- Select Date Record --</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label>Transaction Date</label>
                        <input asp-for="Date" type="datetime-local" class="form-control" />
                    </div>

                    <div class="d-flex justify-content-between mt-4">

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            ⬅ Back
                        </a>

                        <button type="submit" class="btn btn-primary">
                            💾 Save Transaction
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>