@model SalesManagementSystem.Models.SaleTransactionVM

<h2>Assign Sale Transaction Date</h2>

<form asp-action="Create">
    
    <div class="form-group">
        <label>Select Sale Account</label>
        <select asp-for="SaleAcctId" asp-items="Model.SaleAcctList" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Select Sale Date Record</label>
        <select asp-for="SaleDateId" asp-items="Model.SaleDateList" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Transaction Date</label>
        <input asp-for="Date" type="datetime-local" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Save</button>
</form>