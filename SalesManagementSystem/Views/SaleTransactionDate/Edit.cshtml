@model SalesManagementSystem.Models.SaleTransactionDate

<div class="container mt-4">

    <h3 class="mb-4 text-warning">✏️ Edit Sale Transaction Date</h3>

    <div class="card shadow-sm p-4">

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SaleAcctId" />

            <div class="mb-3">
                <label class="form-label">Sale Transaction</label>
                <select asp-for="SaleAcctId"
                        asp-items="ViewBag.SaleTransactions"
                        class="form-select"></select>
            </div>

            <div class="mb-3">
                <label class="form-label">Date Label</label>
                <select asp-for="DateLabelId"
                        asp-items="ViewBag.DateLabels"
                        class="form-select"></select>
            </div>

            <div class="mb-3">
                <label class="form-label">Date</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" asp-route-saleId="@Model.SaleAcctId" class="btn btn-secondary">Back</a>
                <button type="submit" class="btn btn-warning">Update</button>
            </div>

        </form>

    </div>
</div>