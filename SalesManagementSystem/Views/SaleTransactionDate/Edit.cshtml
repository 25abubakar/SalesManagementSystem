@model SalesManagementSystem.Models.SaleTransactionVM

@{
    ViewData["Title"] = "Edit Sale Transaction Date";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">✏️ Edit Sale Transaction Date</h4>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <!-- Hidden ID -->
                <input type="hidden" asp-for="SaleDateId" />

                <div class="row">

                    <!-- Sale Account -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Sale Account</label>
                        <select asp-for="SaleAcctId" asp-items="Model.SaleAcctList" class="form-select"></select>
                    </div>

                    <!-- Sale Date -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Sale Date Ref</label>
                        <select asp-for="SaleDateId" asp-items="Model.SaleDateList" class="form-select"></select>
                    </div>

                    <!-- Actual Date -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Transaction Date</label>
                        <input asp-for="Date" type="date" class="form-control" />
                    </div>

                </div>

                <div class="mt-3">
                    <button asp-action="Index" type="submit" class="btn btn-warning px-4">Update</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Back</a>
                </div>

            </form>

        </div>
    </div>
</div>