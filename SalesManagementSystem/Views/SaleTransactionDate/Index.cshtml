@model IEnumerable<SalesManagementSystem.Models.SaleTransactionDatePivot>
@{
    long? saleId = ViewBag.SaleId;
}

<div class="container mt-4">

    <h3 class="mb-3">📅 Sale Transaction Dates</h3>

    <a asp-action="Create" asp-route-saleId="@saleId" class="btn btn-primary mb-3">
        Assign New Date
    </a>

    @if (saleId != null)
    {
        <div class="alert alert-info">
            Showing transaction dates for SaleId: <strong>@saleId</strong>
            <a asp-action="Index" class="ms-2">Show all</a>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">

            <div class="table-responsive master-table-wrap">
                <table class="table table-bordered table-hover">
                    <thead class="table-Default">
                        <tr>
                            <th>Sale Id</th>
                            <th>Transaction</th>
                            <th>Payment</th>
                            <th>Order</th>
                            <th>Process</th>
                            <th>Sold</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)    
                        {
                            <tr>
                                <td>@item.SaleAcctId</td>
                                <td>@(item.TransactionDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@(item.PaymentDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@(item.OrderDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@(item.ProcessDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@(item.SoldDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>