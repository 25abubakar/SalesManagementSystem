@model IEnumerable<SalesManagementSystem.Models.SaleTransactionDate>

<h2>Sale Transaction Dates</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Assign New Date</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>SaleTransId</th>
            <th>SaleAcct</th>
            <th>SaleDateId</th>
            <th>Date</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SaleTransId</td>
                <td>@item.SaleAcctId</td>
                <td>@item.SaleDateId</td>
                <td>@item.Date?.ToString("yyyy-MM-dd HH:mm")</td>
                <td class="text-center">

                    <a asp-action="Edit" asp-route-id="@item.SaleTransId"
                           class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.SaleTransId"
                           class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </a>

                </td>
            </tr>
        }
    </tbody>
</table>