@model SalesManagementSystem.Models.SaleProduct

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-4">
    <h2>Edit Product</h2>

    <form asp-action="Edit" asp-route-id="@Model.ProductId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />

        <div class="row">
            <div class="col-md-6">
                <label class="form-label">Product Name</label>
                <input asp-for="ProductName" class="form-control" />
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Platform</label>
                <select asp-for="PlatformId" class="form-select" asp-items="ViewBag.Platforms">
                    <option value="">-- Select Platform --</option>
                </select>
            </div>

            <div class="col-md-3 mt-3">
                <label class="form-label">CompanyId</label>
                <input asp-for="CompanyId" class="form-control" />
            </div>

            <div class="col-md-3 mt-3">
                <label class="form-label">Is Active</label>
                <select asp-for="IsActive" class="form-select">
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-warning">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

