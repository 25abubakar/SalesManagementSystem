@model SalesManagementSystem.Models.SaleProduct

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <h2>Product Details</h2>

    <dl class="row">
        <dt class="col-sm-3">Id</dt>
        <dd class="col-sm-9">@Model.ProductId</dd>

        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.ProductName</dd>

        <dt class="col-sm-3">Platform</dt>
        <dd class="col-sm-9">@Model.Platform?.PlatformName</dd>

        <dt class="col-sm-3">CompanyId</dt>
        <dd class="col-sm-9">@Model.CompanyId</dd>

        <dt class="col-sm-3">Active</dt>
        <dd class="col-sm-9">@Model.IsActive</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

