<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sales Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SalesManagementSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
            html, body {
                height: 100%;
            }

            body {
                background: #f5f7fb;
                display: flex;
                flex-direction: column;
                padding-top: 70px;
            }

            .navbar {
                background: linear-gradient(90deg,#0d6efd,#4e73df);
                padding: 12px 20px;
                z-index: 9999;
            }

            .navbar-brand {
                font-weight: 700;
                font-size: 22px;
                color: white !important;
            }

            .nav-link {
                color: white !important;
                font-weight: 500;
            }

            .dropdown-menu {
                border-radius: 12px;
                border: none;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }

            .main-wrapper {
                flex: 1;
            }

            .container {
                max-width: 1200px;
            }

            footer {
                margin-top: auto;
                background: white;
                border-top: 1px solid #eee;
                padding: 15px;
                text-align: center;
                box-shadow: 0 -3px 10px rgba(0,0,0,0.05);
            }

                footer img {
                    margin-left: 8px;
                    transition: .2s;
                }

                    footer img:hover {
                        transform: scale(1.2);
                    }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm fixed-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-graph-up-arrow"></i> SalesMS
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExample">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarsExample">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Home
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-cart"></i> Transaction Type Date
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="SaleDate" asp-action="Index"> Sale Type Label</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleTransactionDate" asp-action="Index">Transaction Date List</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleTransactionDate" asp-action="Create">Transaction Date</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-cart"></i> Sales
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="SaleAcct" asp-action="Index">Sales List</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleAcct" asp-action="Create">New Sale</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleCharge" asp-action="Index">Sale Charges</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-gear"></i> Masters
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="SalePlatform" asp-action="Index">Platforms</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleProduct" asp-action="Index">Products</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleAccount" asp-action="Index">Accounts</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleTransactionType" asp-action="Index">Transaction Types</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleStatus" asp-action="Index">Statuses</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleChargeType" asp-action="Index">Charge Types</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock"></i> Privacy
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout">
                                Logout
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ⭐ MAIN WRAPPER -->
    <div class="main-wrapper">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </div>

    <footer>
        © @DateTime.Now.Year Sales Management System — Made by Abubakar
        <a href="mailto:muhammadabubakarkhan1234@gmail.com">
            <img src="~/images/mail.jpg" width="26">
            </a>
            <a href="https://github.com/25abubakar/Campus-Management-System" target="_blank">
                <img src="~/images/git.webp" width="26">
                </a>
            </footer>

            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
            <script src="~/js/site.js" asp-append-version="true"></script>
            @await RenderSectionAsync("Scripts", required: false)

        </body>
    </html>