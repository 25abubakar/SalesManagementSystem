@model SalesManagementSystem.Models.SaleAcctCreateVM
@{
    ViewData["Title"] = "Create Sale";
    var dateLabelOptions = ViewBag.DateLabels as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var chargeTypeOptions = ViewBag.ChargeTypes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<style>
    body { background: #f5f7fb; }
    .page-header { background: linear-gradient(135deg,#0d6efd,#4e73df); color: white; padding: 30px; border-radius: 16px; margin-bottom: 25px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    .card-section { background: white; border: none; border-radius: 16px; box-shadow: 0 8px 22px rgba(0,0,0,0.06); padding: 25px; margin-bottom: 20px; transition: .2s; }
    .card-section:hover { transform: translateY(-2px); }
    .section-title { display: flex; align-items: center; gap: 8px; font-weight: 700; margin-bottom: 18px; color: #0d6efd; }
    .form-control, .form-select { border-radius: 10px; padding: 10px 12px; border: 1px solid #e5e7eb; transition: .2s; }
    .form-control:focus, .form-select:focus { border-color: #0d6efd; box-shadow: 0 0 0 .2rem rgba(13,110,253,.15); }
    label { font-weight: 600; font-size: 13px; color: #555; margin-bottom: 5px; }
    .sticky-actions { position: sticky; bottom: 20px; background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); padding: 15px; border-radius: 14px; box-shadow: 0 10px 25px rgba(0,0,0,0.12); display: flex; justify-content: flex-end; gap: 10px; z-index: 1000; }
    .btn { border-radius: 10px; padding: 8px 18px; font-weight: 600; }
    .transaction-row, .charge-row { border: 1px solid #e9ecef; border-radius: 12px; padding: 16px; background: #f8fafc; }
</style>

<div class="container mt-4">
    <div class="page-header text-center">
        <h2><i class="bi bi-cart-plus"></i> Create New Sale</h2>
        <p class="mb-0">Fill all required fields to generate a new sales record</p>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-info-circle"></i> Basic Information</div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label>Company ID</label>
                    <input asp-for="CompanyId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Platform</label>
                    <select asp-for="PlatformId" class="form-select" asp-items="ViewBag.Platforms">
                        <option value="">Select Platform</option>
                        </select>
                </div>
                <div class="col-md-3">
                    <label>Product</label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.Products">
                        <option value="">Select Product</option>
                        </select>
                </div>
                <div class="col-md-3">
                    <label>Order ID</label>
                    <input asp-for="OrderID" class="form-control" />
                </div>
            </div>
        </div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-cash-coin"></i> Quantity & Amounts</div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label>Qty Sold</label>
                    <input asp-for="QtySold" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Qty Held</label>
                    <input asp-for="QtyHeld" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Sold Amount</label>
                    <input asp-for="SoldAmount" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Cost Amount</label>
                    <input asp-for="CostAmount" class="form-control" />
                </div>
            </div>
        </div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-receipt"></i> Charges & Rebates</div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label>Pro Charges</label>
                    <input asp-for="TotalProCharges" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>Amazon Fee</label>
                    <input asp-for="AmazonFee" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>Other</label>
                    <input asp-for="OtherCharges" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>Promotion</label>
                    <input asp-for="TotalPromotion" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>RRO Rebate</label>
                    <input asp-for="TotalRroRebate" class="form-control" />
                </div>
            </div>
        </div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-diagram-3"></i> Accounts & Status</div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label>Transaction Type</label>
                    <select asp-for="TransactionId" class="form-select" asp-items="ViewBag.TransTypes">
                        <option value="">-- Select --</option>
                        </select>
                </div>
                <div class="col-md-3">
                    <label>From Account</label>
                    <select asp-for="FromAccountId" class="form-select" asp-items="ViewBag.FromAccounts">
                        <option value="">-- Select --</option>
                        </select>
                </div>
                <div class="col-md-3">
                    <label>To Account</label>
                    <select asp-for="ToAccountId" class="form-select" asp-items="ViewBag.ToAccounts">
                        <option value="">-- Select --</option>
                        </select>
                </div>
                <div class="col-md-3">
                    <label>Status</label>
                    <select asp-for="StatusID" class="form-select" asp-items="ViewBag.Statuses">
                        <option value="">-- Select --</option>
                        </select>
                </div>
            </div>
        </div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-list-stars"></i> Additional Details</div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label>Amz Pro Ref</label>
                    <input asp-for="AmzProRef" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Action</label>
                    <input asp-for="Action" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Created Date</label>
                    <input asp-for="CreatedDate" type="datetime-local" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label>Description</label>
                    <input asp-for="Discription" class="form-control" />
                </div>
                <div class="col-md-12 d-flex justify-content-end">
                    <button type="button" id="addChargeRow" class="btn btn-outline-success me-2">
                        <i class="bi bi-plus-circle"></i> Add Charge
                    </button>
                    <button type="button" id="addTransactionDateRow" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle"></i> Add Transaction Date
                    </button>
                </div>
            </div>
        </div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-journal-check"></i> Sale Charges</div>
            <div id="chargeRows" class="d-grid gap-3">
                @if (Model.Charges.Any())
                {
                    for (var i = 0; i < Model.Charges.Count; i++)
                    {
                        <div class="charge-row row g-3 align-items-end">
                            <input type="hidden" name="Charges[@i].SaleChargeId" value="@Model.Charges[i].SaleChargeId" />
                            <div class="col-md-4">
                                <label>Charge Type</label>
                                <select name="Charges[@i].ChargeTypeId" class="form-select">
                                    <option value="">-- Select Charge Type --</option>
                                    @foreach (var option in chargeTypeOptions)
                                    {
                                        if (option.Value == Model.Charges[i].ChargeTypeId?.ToString())
                                        {
                                            <option value="@option.Value" selected>@option.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Value">@option.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label>Amount</label>
                                <input name="Charges[@i].Amount" class="form-control" value="@Model.Charges[i].Amount" />
                            </div>
                            <div class="col-md-4">
                                <label>Remarks</label>
                                <input name="Charges[@i].Remarks" class="form-control" value="@Model.Charges[i].Remarks" />
                            </div>
                            <div class="col-md-1">
                                <button type="button" class="btn btn-outline-danger w-100 remove-charge-row">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small" id="chargeEmptyState">No charge rows added yet.</div>
                }
            </div>
        </div>

        <div class="card-section">
            <div class="section-title"><i class="bi bi-calendar-event"></i> Sale Transaction Dates</div>
            <div id="transactionDateRows" class="d-grid gap-3">
                @if (Model.SaleTransactionDates.Any())
                {
                    for (var i = 0; i < Model.SaleTransactionDates.Count; i++)
                    {
                        <div class="transaction-row row g-3 align-items-end">
                            <div class="col-md-5">
                                <label>Date Label</label>
                                <select name="SaleTransactionDates[@i].DateLabelId" class="form-select">
                                    <option value="">-- Select Label --</option>
                                    @foreach (var option in dateLabelOptions)
                                    {
                                        if (option.Value == Model.SaleTransactionDates[i].DateLabelId?.ToString())
                                        {
                                            <option value="@option.Value" selected>@option.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Value">@option.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-5">
                                <label>Date</label>
                                <input name="SaleTransactionDates[@i].Date"
                                       type="date"
                                       value="@(Model.SaleTransactionDates[i].Date?.ToString("yyyy-MM-dd"))"
                                       class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-danger w-100 remove-transaction-row">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small" id="transactionDateEmptyState">No transaction date rows added yet.</div>
                }
            </div>
        </div>

        <div class="sticky-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left">

                </i>
                Back
            </a>
            <button type="submit" class="btn btn-success" id="saveSaleButton">
                <i class="bi bi-check-circle">
                </i>
                Save Sale
            </button>
        </div>
    </form>
</div>

<template id="transactionDateRowTemplate">
    <div class="transaction-row row g-3 align-items-end">
        <div class="col-md-5">
            <label>Date Label</label>
            <select data-name="DateLabelId" class="form-select">
                <option value="">-- Select Label --</option>
                @foreach (var option in dateLabelOptions)
                {
                    <option value="@option.Value">@option.Text</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label>Date</label>
            <input data-name="Date" type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-danger w-100 remove-transaction-row">
                <i class="bi bi-trash">

                </i>
                Remove
            </button>
        </div>
    </div>
</template>

<template id="chargeRowTemplate">
    <div class="charge-row row g-3 align-items-end">
        <input type="hidden" data-name="SaleChargeId" value="" />
        <div class="col-md-4">
            <label>Charge Type</label>
            <select data-name="ChargeTypeId" class="form-select">
                <option value="">-- Select Charge Type --</option>
                @foreach (var option in chargeTypeOptions)
                {
                    <option value="@option.Value">@option.Text</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label>Amount</label>
            <input data-name="Amount" class="form-control" />
        </div>
        <div class="col-md-4">
            <label>Remarks</label>
            <input data-name="Remarks" class="form-control" />
        </div>
        <div class="col-md-1">
            <button type="button" class="btn btn-outline-danger w-100 remove-charge-row">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const chargeContainer = document.getElementById('chargeRows');
            const addChargeButton = document.getElementById('addChargeRow');
            const chargeTemplate = document.getElementById('chargeRowTemplate');
            const container = document.getElementById('transactionDateRows');
            const addButton = document.getElementById('addTransactionDateRow');
            const template = document.getElementById('transactionDateRowTemplate');

            function updateEmptyState(targetContainer, rowClass, emptyStateId, text) {
                const rows = targetContainer.querySelectorAll(`.${rowClass}`);
                const emptyState = document.getElementById(emptyStateId);

                if (rows.length === 0) {
                    if (!emptyState) {
                        const placeholder = document.createElement('div');
                        placeholder.id = emptyStateId;
                        placeholder.className = 'text-muted small';
                        placeholder.textContent = text;
                        targetContainer.appendChild(placeholder);
                    }
                } else if (emptyState) {
                    emptyState.remove();
                }
            }

            function reindexRows(targetContainer, rowClass, prefix) {
                const rows = targetContainer.querySelectorAll(`.${rowClass}`);
                rows.forEach((row, index) => {
                    row.querySelectorAll('[data-name], [name]').forEach((field) => {
                        const propertyName = field.dataset.name || field.name.split('.').pop();
                        field.name = `${prefix}[${index}].${propertyName}`;
                    });
                });
            }

            function addChargeRow() {
                const row = chargeTemplate.content.firstElementChild.cloneNode(true);
                chargeContainer.appendChild(row);
                updateEmptyState(chargeContainer, 'charge-row', 'chargeEmptyState', 'No charge rows added yet.');
                reindexRows(chargeContainer, 'charge-row', 'Charges');
                refreshChargeTypeSelections();
            }

            function addTransactionRow() {
                const row = template.content.firstElementChild.cloneNode(true);
                container.appendChild(row);
                updateEmptyState(container, 'transaction-row', 'transactionDateEmptyState', 'No transaction date rows added yet.');
                reindexRows(container, 'transaction-row', 'SaleTransactionDates');
                refreshDateLabelSelections();
            }

            function refreshDateLabelSelections() {
                const selects = container.querySelectorAll('select[name$=".DateLabelId"]');
                const selectedValues = new Set();

                selects.forEach((select) => {
                    if (select.value) {
                        selectedValues.add(select.value);
                    }
                });

                selects.forEach((select) => {
                    const currentValue = select.value;
                    Array.from(select.options).forEach((option) => {
                        if (!option.value) {
                            option.disabled = false;
                            return;
                        }

                        option.disabled = option.value !== currentValue && selectedValues.has(option.value);
                    });
                });
            }

            function refreshChargeTypeSelections() {
                const selects = chargeContainer.querySelectorAll('select[name$=".ChargeTypeId"]');
                const selectedValues = new Set();

                selects.forEach((select) => {
                    if (select.value) {
                        selectedValues.add(select.value);
                    }
                });

                selects.forEach((select) => {
                    const currentValue = select.value;
                    Array.from(select.options).forEach((option) => {
                        if (!option.value) {
                            option.disabled = false;
                            return;
                        }

                        option.disabled = option.value !== currentValue && selectedValues.has(option.value);
                    });
                });
            }

            addChargeButton.addEventListener('click', addChargeRow);
            addButton.addEventListener('click', addTransactionRow);
            chargeContainer.addEventListener('change', (event) => {
                if (event.target.matches('select[name$=".ChargeTypeId"]')) {
                    refreshChargeTypeSelections();
                }
            });
            container.addEventListener('change', (event) => {
                if (event.target.matches('select[name$=".DateLabelId"]')) {
                    refreshDateLabelSelections();
                }
            });

            chargeContainer.addEventListener('click', (event) => {
                const button = event.target.closest('.remove-charge-row');
                if (!button) {
                    return;
                }

                button.closest('.charge-row')?.remove();
                updateEmptyState(chargeContainer, 'charge-row', 'chargeEmptyState', 'No charge rows added yet.');
                reindexRows(chargeContainer, 'charge-row', 'Charges');
                refreshChargeTypeSelections();
            });

            container.addEventListener('click', (event) => {
                const button = event.target.closest('.remove-transaction-row');
                if (!button) {
                    return;
                }

                button.closest('.transaction-row')?.remove();
                updateEmptyState(container, 'transaction-row', 'transactionDateEmptyState', 'No transaction date rows added yet.');
                reindexRows(container, 'transaction-row', 'SaleTransactionDates');
                refreshDateLabelSelections();
            });

            updateEmptyState(chargeContainer, 'charge-row', 'chargeEmptyState', 'No charge rows added yet.');
            reindexRows(chargeContainer, 'charge-row', 'Charges');
            updateEmptyState(container, 'transaction-row', 'transactionDateEmptyState', 'No transaction date rows added yet.');
            reindexRows(container, 'transaction-row', 'SaleTransactionDates');
            refreshChargeTypeSelections();
            refreshDateLabelSelections();

            const form = document.querySelector('form[asp-action="Create"], form');
            form.addEventListener('submit', () => {
                const saveButton = document.getElementById('saveSaleButton');
                if (saveButton) {
                    saveButton.disabled = true;
                    saveButton.innerHTML = '<i class="bi bi-hourglass-split"></i> Saving...';
                }
            });
        })();
    </script>
}