@model SalesManagementSystem.Models.SaleAcctCreateVM
@{
    ViewData["Title"] = "Edit Sale";
    var dateLabelOptions = ViewBag.DateLabels as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var chargeTypeOptions = ViewBag.ChargeTypes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var platformOptions = ViewBag.PlatformOptions as IEnumerable<SalesManagementSystem.Models.SalePlatform>
        ?? Enumerable.Empty<SalesManagementSystem.Models.SalePlatform>();
    var productOptions = ViewBag.ProductOptions as IEnumerable<SalesManagementSystem.Models.SaleProduct>
        ?? Enumerable.Empty<SalesManagementSystem.Models.SaleProduct>();
}

<div class="container mt-4">
    <h2>Edit Sale</h2>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-4">
                <label>Company ID</label>
                <input asp-for="CompanyId" class="form-control" id="companyIdInput" readonly />
            </div>
            <div class="col-md-4">
                <label>Platform</label>
                <select asp-for="PlatformId" class="form-select" id="platformSelect">
                    <option value="">-- Select Platform --</option>
                    @foreach (var platform in platformOptions)
                    {
                        if (Model.PlatformId == platform.PlatformId)
                        {
                            <option value="@platform.PlatformId" data-company-id="@platform.CompanyId" selected>@platform.PlatformName</option>
                        }
                        else
                        {
                            <option value="@platform.PlatformId" data-company-id="@platform.CompanyId">@platform.PlatformName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Product</label>
                <select asp-for="ProductId" class="form-select" id="productSelect">
                    <option value="">-- Select Product --</option>
                    @foreach (var product in productOptions)
                    {
                        if (Model.ProductId == product.ProductId)
                        {
                            <option value="@product.ProductId" data-platform-id="@product.PlatformId" selected>@product.ProductName</option>
                        }
                        else
                        {
                            <option value="@product.ProductId" data-platform-id="@product.PlatformId">@product.ProductName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Order ID</label>
                <input asp-for="OrderID" class="form-control" />
            </div>
            <div class="col-md-4">
                <label>Qty Sold</label>
                <input asp-for="QtySold" class="form-control" />
            </div>
            <div class="col-md-4">
                <label>Qty Held</label>
                <input asp-for="QtyHeld" class="form-control" />
            </div>
            <div class="col-md-4">
                <label>Sold Amount</label>
                <input asp-for="SoldAmount" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Cost Amount</label>
                <input asp-for="CostAmount" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Total Pro Charges</label>
                <input asp-for="TotalProCharges" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Amazon Fee</label>
                <input asp-for="AmazonFee" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Other Charges</label>
                <input asp-for="OtherCharges" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Total Promotion</label>
                <input asp-for="TotalPromotion" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Total RRO Rebate</label>
                <input asp-for="TotalRroRebate" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Transaction Type</label>
                <select asp-for="TransactionId" class="form-select" asp-items="ViewBag.TransTypes">
                    <option value="">-- Select Transaction Type --</option>
                </select>
            </div>
            <div class="col-md-4 mt-3">
                <label>From Account</label>
                <select asp-for="FromAccountId" class="form-select" asp-items="ViewBag.FromAccounts">
                    <option value="">-- Select From Account --</option>
                </select>
            </div>
            <div class="col-md-4 mt-3">
                <label>To Account</label>
                <select asp-for="ToAccountId" class="form-select" asp-items="ViewBag.ToAccounts">
                    <option value="">-- Select To Account --</option>
                </select>
            </div>
            <div class="col-md-4 mt-3">
                <label>Status</label>
                <select asp-for="StatusID" class="form-select" asp-items="ViewBag.Statuses">
                    <option value="">-- Select Status --</option>
                </select>
            </div>
            <div class="col-md-4 mt-3">
                <label>Amz Pro Ref</label>
                <input asp-for="AmzProRef" class="form-control" />
            </div>
            <div class="col-md-8 mt-3">
                <label>Description</label>
                <input asp-for="Discription" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Action</label>
                <input asp-for="Action" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Created Date</label>
                <input asp-for="CreatedDate" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-4 mt-3">
                <label>Profit Amount</label>
                <input asp-for="ProfitAmount" class="form-control" readonly />
            </div>
        </div>

        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h4 class="mb-0">Charges</h4>
                <button type="button" id="addChargeRow" class="btn btn-sm btn-success">Add Row</button>
            </div>
            <div id="chargeRows" class="d-grid gap-2">
                @if (Model.Charges.Any())
                {
                    for (var i = 0; i < Model.Charges.Count; i++)
                    {
                        <div class="row g-2 border rounded p-2 charge-row">
                            <input type="hidden" name="Charges[@i].SaleChargeId" value="@Model.Charges[i].SaleChargeId" />
                            <div class="col-md-4">
                                <label>Charge Type</label>
                                <select name="Charges[@i].ChargeTypeId" class="form-select">
                                    <option value="">-- Select --</option>
                                    @foreach (var option in chargeTypeOptions)
                                    {
                                        if (option.Value == Model.Charges[i].ChargeTypeId?.ToString())
                                        {
                                            <option value="@option.Value" selected>@option.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Value">@option.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label>Amount</label>
                                <input name="Charges[@i].Amount" class="form-control" value="@Model.Charges[i].Amount" />
                            </div>
                            <div class="col-md-4">
                                <label>Remarks</label>
                                <input name="Charges[@i].Remarks" class="form-control" value="@Model.Charges[i].Remarks" />
                            </div>
                            <div class="col-md-1 d-flex align-items-end">
                                <button type="button" class="btn btn-sm btn-danger remove-charge-row">Delete</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small" id="chargeEmptyState">No charges added yet.</div>
                }
            </div>
        </div>

        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h4 class="mb-0">Transaction Dates</h4>
                <button type="button" id="addTransactionDateRow" class="btn btn-sm btn-success">Add Row</button>
            </div>
            <div id="transactionDateRows" class="d-grid gap-2">
                @if (Model.SaleTransactionDates.Any())
                {
                    for (var i = 0; i < Model.SaleTransactionDates.Count; i++)
                    {
                        <div class="row g-2 border rounded p-2 transaction-row">
                            <div class="col-md-5">
                                <label>Date Label</label>
                                <select name="SaleTransactionDates[@i].DateLabelId" class="form-select">
                                    <option value="">-- Select --</option>
                                    @foreach (var option in dateLabelOptions)
                                    {
                                        if (option.Value == Model.SaleTransactionDates[i].DateLabelId?.ToString())
                                        {
                                            <option value="@option.Value" selected>@option.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Value">@option.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-5">
                                <label>Date</label>
                                <input type="date" name="SaleTransactionDates[@i].Date" class="form-control" value="@(Model.SaleTransactionDates[i].Date?.ToString("yyyy-MM-dd"))" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-sm btn-danger remove-transaction-row">Delete</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small" id="transactionEmptyState">No transaction dates added yet.</div>
                }
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning" id="updateSaleButton">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

<template id="chargeRowTemplate">
    <div class="row g-2 border rounded p-2 charge-row">
        <input type="hidden" data-name="SaleChargeId" value="" />
        <div class="col-md-4">
            <label>Charge Type</label>
            <select data-name="ChargeTypeId" class="form-select">
                <option value="">-- Select --</option>
                @foreach (var option in chargeTypeOptions)
                {
                    <option value="@option.Value">@option.Text</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label>Amount</label>
            <input data-name="Amount" class="form-control" />
        </div>
        <div class="col-md-4">
            <label>Remarks</label>
            <input data-name="Remarks" class="form-control" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button type="button" class="btn btn-sm btn-danger remove-charge-row">Delete</button>
        </div>
    </div>
</template>

<template id="transactionRowTemplate">
    <div class="row g-2 border rounded p-2 transaction-row">
        <div class="col-md-5">
            <label>Date Label</label>
            <select data-name="DateLabelId" class="form-select">
                <option value="">-- Select --</option>
                @foreach (var option in dateLabelOptions)
                {
                    <option value="@option.Value">@option.Text</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label>Date</label>
            <input type="date" data-name="Date" class="form-control" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="button" class="btn btn-sm btn-danger remove-transaction-row">Delete</button>
        </div>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const chargeRows = document.getElementById('chargeRows');
            const transactionRows = document.getElementById('transactionDateRows');
            const chargeTemplate = document.getElementById('chargeRowTemplate');
            const transactionTemplate = document.getElementById('transactionRowTemplate');
            const platformSelect = document.getElementById('platformSelect');
            const companyIdInput = document.getElementById('companyIdInput');
            const productSelect = document.getElementById('productSelect');

            function syncCompanyFromPlatform() {
                if (!platformSelect || !companyIdInput) {
                    return;
                }

                const selectedOption = platformSelect.options[platformSelect.selectedIndex];
                companyIdInput.value = selectedOption?.dataset.companyId ?? '';
            }

            function syncProductsByPlatform() {
                if (!platformSelect || !productSelect) {
                    return;
                }

                const selectedPlatform = platformSelect.value;
                Array.from(productSelect.options).forEach((option) => {
                    if (!option.value) {
                        option.hidden = false;
                        option.disabled = false;
                        return;
                    }

                    const matchesPlatform = !selectedPlatform || option.dataset.platformId === selectedPlatform;
                    option.hidden = !matchesPlatform;
                    option.disabled = !matchesPlatform;
                });

                const currentSelection = productSelect.options[productSelect.selectedIndex];
                if (currentSelection && currentSelection.value && currentSelection.disabled) {
                    productSelect.value = '';
                }
            }

            function reindex(container, rowClass, prefix) {
                const rows = container.querySelectorAll(`.${rowClass}`);
                rows.forEach((row, index) => {
                    row.querySelectorAll('[data-name], [name]').forEach((field) => {
                        const prop = field.dataset.name || field.name.split('.').pop();
                        field.name = `${prefix}[${index}].${prop}`;
                    });
                });
            }

            function updateEmpty(container, rowClass, id, text) {
                const hasRows = container.querySelectorAll(`.${rowClass}`).length > 0;
                const empty = document.getElementById(id);
                if (hasRows && empty) empty.remove();
                if (!hasRows && !empty) {
                    const div = document.createElement('div');
                    div.id = id;
                    div.className = 'text-muted small';
                    div.textContent = text;
                    container.appendChild(div);
                }
            }

            function refreshDateLabelSelections() {
                const selects = transactionRows.querySelectorAll('select[name$=".DateLabelId"]');
                const selectedValues = new Set();

                selects.forEach((select) => {
                    if (select.value) {
                        selectedValues.add(select.value);
                    }
                });

                selects.forEach((select) => {
                    const currentValue = select.value;
                    Array.from(select.options).forEach((option) => {
                        if (!option.value) {
                            option.disabled = false;
                            return;
                        }

                        option.disabled = option.value !== currentValue && selectedValues.has(option.value);
                    });
                });
            }

            function refreshChargeTypeSelections() {
                const selects = chargeRows.querySelectorAll('select[name$=".ChargeTypeId"]');
                const selectedValues = new Set();

                selects.forEach((select) => {
                    if (select.value) {
                        selectedValues.add(select.value);
                    }
                });

                selects.forEach((select) => {
                    const currentValue = select.value;
                    Array.from(select.options).forEach((option) => {
                        if (!option.value) {
                            option.disabled = false;
                            return;
                        }

                        option.disabled = option.value !== currentValue && selectedValues.has(option.value);
                    });
                });
            }

            document.getElementById('addChargeRow').addEventListener('click', () => {
                chargeRows.appendChild(chargeTemplate.content.firstElementChild.cloneNode(true));
                reindex(chargeRows, 'charge-row', 'Charges');
                updateEmpty(chargeRows, 'charge-row', 'chargeEmptyState', 'No charges added yet.');
                refreshChargeTypeSelections();
            });

            document.getElementById('addTransactionDateRow').addEventListener('click', () => {
                transactionRows.appendChild(transactionTemplate.content.firstElementChild.cloneNode(true));
                reindex(transactionRows, 'transaction-row', 'SaleTransactionDates');
                updateEmpty(transactionRows, 'transaction-row', 'transactionEmptyState', 'No transaction dates added yet.');
                refreshDateLabelSelections();
            });

            transactionRows.addEventListener('change', (e) => {
                if (e.target.matches('select[name$=".DateLabelId"]')) {
                    refreshDateLabelSelections();
                }
            });

            chargeRows.addEventListener('change', (e) => {
                if (e.target.matches('select[name$=".ChargeTypeId"]')) {
                    refreshChargeTypeSelections();
                }
            });

            chargeRows.addEventListener('click', (e) => {
                if (e.target.closest('.remove-charge-row')) {
                    e.target.closest('.charge-row')?.remove();
                    reindex(chargeRows, 'charge-row', 'Charges');
                    updateEmpty(chargeRows, 'charge-row', 'chargeEmptyState', 'No charges added yet.');
                    refreshChargeTypeSelections();
                }
            });

            transactionRows.addEventListener('click', (e) => {
                if (e.target.closest('.remove-transaction-row')) {
                    e.target.closest('.transaction-row')?.remove();
                    reindex(transactionRows, 'transaction-row', 'SaleTransactionDates');
                    updateEmpty(transactionRows, 'transaction-row', 'transactionEmptyState', 'No transaction dates added yet.');
                    refreshDateLabelSelections();
                }
            });

            reindex(chargeRows, 'charge-row', 'Charges');
            reindex(transactionRows, 'transaction-row', 'SaleTransactionDates');
            updateEmpty(chargeRows, 'charge-row', 'chargeEmptyState', 'No charges added yet.');
            updateEmpty(transactionRows, 'transaction-row', 'transactionEmptyState', 'No transaction dates added yet.');
            refreshChargeTypeSelections();
            refreshDateLabelSelections();
            platformSelect?.addEventListener('change', syncCompanyFromPlatform);
            platformSelect?.addEventListener('change', syncProductsByPlatform);
            syncCompanyFromPlatform();
            syncProductsByPlatform();

            const form = document.querySelector('form');
            form.addEventListener('submit', () => {
                const updateButton = document.getElementById('updateSaleButton');
                if (updateButton) {
                    updateButton.disabled = true;
                    updateButton.textContent = 'Updating...';
                }
            });
        })();
    </script>
}