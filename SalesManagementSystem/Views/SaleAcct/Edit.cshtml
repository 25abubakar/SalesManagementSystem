@model SalesManagementSystem.Models.SaleAcct

@{
    ViewData["Title"] = "Edit Sale";
}

<div class="container mt-4">
    <h2>Edit Sale</h2>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">

            <div class="col-md-4">
                <label>Platform</label>
                <select asp-for="PlatformId" class="form-select" asp-items="ViewBag.Platforms">
                    <option value="">-- Select Platform --</option>
                </select>
            </div>

            <div class="col-md-4">
                <label>Product</label>
                <select asp-for="ProductId" class="form-select" asp-items="ViewBag.Products">
                    <option value="">-- Select Product --</option>
                </select>
            </div>

            <div class="col-md-4">
                <label>Qty Sold</label>
                <input asp-for="QtySold" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>Qty Held</label>
                <input asp-for="QtyHeld" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>Sold Amount</label>
                <input asp-for="SoldAmount" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Cost Amount</label>
                <input asp-for="CostAmount" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Total Pro Charges</label>
                <input asp-for="TotalProCharges" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Amazon Fee</label>
                <input asp-for="AmazonFee" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Other Charges</label>
                <input asp-for="OtherCharges" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Total Promotion</label>
                <input asp-for="TotalPromotion" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Total RRO Rebate</label>
                <input asp-for="TotalRroRebate" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Transaction Type</label>
                <select asp-for="TransactionId" class="form-select" asp-items="ViewBag.TransTypes">
                    <option value="">-- Select Transaction Type --</option>
                </select>
            </div>

            <div class="col-md-4 mt-3">
                <label>From Account</label>
                <select asp-for="FromAccountId" class="form-select" asp-items="ViewBag.FromAccounts">
                    <option value="">-- Select From Account --</option>
                </select>
            </div>

            <div class="col-md-4 mt-3">
                <label>To Account</label>
                <select asp-for="ToAccountId" class="form-select" asp-items="ViewBag.ToAccounts">
                    <option value="">-- Select To Account --</option>
                </select>
            </div>

            <div class="col-md-4 mt-3">
                <label>Status</label>
                <select asp-for="StatusID" class="form-select" asp-items="ViewBag.Statuses">
                    <option value="">-- Select Status --</option>
                </select>
            </div>

            <div class="col-md-4 mt-3">
                <label>Amz Pro Ref</label>
                <input asp-for="AmzProRef" class="form-control" />
            </div>

            <div class="col-md-8 mt-3">
                <label>Description</label>
                <input asp-for="Discription" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Action</label>
                <input asp-for="Action" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Created Date</label>
                <input asp-for="CreatedDate" type="datetime-local" class="form-control" />
            </div>

            <div class="col-md-4 mt-3">
                <label>Profit Amount</label>
                <input asp-for="ProfitAmount" class="form-control" readonly />
            </div>

        </div>

        <br />
        <button type="submit" class="btn btn-warning">Update</button>
        <a asp-controller="SaleCharge" asp-action="Create" asp-route-saleId="@Model.Id" class="btn btn-dark">Add Charge</a>
        <a asp-controller="SaleTransactionDate" asp-action="Create" asp-route-saleId="@Model.Id" class="btn btn-primary">Add Transaction Date</a>
        <a asp-controller="SaleCharge" asp-action="Index" asp-route-saleId="@Model.Id" class="btn btn-outline-dark">View Charges</a>
        <a asp-controller="SaleTransactionDate" asp-action="Index" asp-route-saleId="@Model.Id" class="btn btn-outline-primary">View Transactions</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>

    <div class="mt-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="mb-0">Charges</h4>
            <a asp-controller="SaleCharge" asp-action="Create" asp-route-saleId="@Model.Id" class="btn btn-sm btn-success">Add Row</a>
        </div>
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Charge Type</th>
                    <th>Amount</th>
                    <th>Remarks</th>
                    <th style="width:170px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Charges != null && Model.Charges.Any())
                {
                    @foreach (var charge in Model.Charges)
                    {
                        <tr>
                            <td>@charge.ChargeType?.ChargeTypeName</td>
                            <td>@charge.Amount</td>
                            <td>@charge.Remarks</td>
                            <td>
                                <a asp-controller="SaleCharge" asp-action="Edit" asp-route-id="@charge.SaleChargeId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-controller="SaleCharge" asp-action="Delete" asp-route-id="@charge.SaleChargeId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No charges added yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="mb-0">Transaction Dates</h4>
            <a asp-controller="SaleTransactionDate" asp-action="Create" asp-route-saleId="@Model.Id" class="btn btn-sm btn-success">Add Row</a>
        </div>
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Date Label</th>
                    <th>Date</th>
                    <th style="width:170px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.SaleTransactionDates != null && Model.SaleTransactionDates.Any())
                {
                    @foreach (var item in Model.SaleTransactionDates)
                    {
                        <tr>
                            <td>@item.SaleDate?.DateLabel</td>
                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-controller="SaleTransactionDate" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-controller="SaleTransactionDate" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center">No transaction dates added yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}