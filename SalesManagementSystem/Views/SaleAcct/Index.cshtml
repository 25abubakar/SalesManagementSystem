@model IEnumerable<SalesManagementSystem.Models.SaleAcct>

@{
    ViewData["Title"] = "Sales List";
}

<div class="container mt-4">

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <h2 class="mb-2 mb-md-0">Sales Management</h2>
        <span id="realtimeStatus" class="badge text-bg-success ms-2">Real-time: Connected</span>
        <a asp-action="Create" class="btn btn-primary">
            + Add New Sale
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-Default text-nowrap">
                        <tr>
                            <th>Platform</th>
                            <th>Product</th>
                            <th>Order ID</th>
                            @* <th>Qty</th> *@
                            <th>Sold</th>
                            <th>From Account</th>
                            <th>To Account</th>
                            <th>Cost</th>
                            <th>Profit</th>
                            <th>Status</th>
                            <th>Charges</th>
                            <th>Transactions</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@item.Platform?.PlatformName</td>
                                <td class="text-nowrap">@item.Product?.ProductName</td>
                                <td>@item.OrderID</td>
                                @* <td>@item.QtySold</td> *@
                                <td>@item.SoldAmount</td>
                                <td>@(item.FromAccount?.AccountName ?? item.FromAccountId?.ToString())</td>
                                <td>@(item.ToAccount?.AccountName ?? item.ToAccountId?.ToString())</td>
                                <td>@item.CostAmount</td>

                                <td class="fw-bold text-success">
                                    @item.ProfitAmount
                                </td>

                                <td>
                                    @(item.StatusMaster?.StatusName ?? item.Status)
                                </td>

                                <td style="min-width:220px;">
                                    @if (!string.IsNullOrWhiteSpace(item.ChargeTypesCsv))
                                    {
                                        <small>@item.ChargeTypesCsv</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No charges</span>
                                    }
                                </td>

                                <td style="min-width:220px;">
                                    @if (!string.IsNullOrWhiteSpace(item.TransactionDatesCsv))
                                    {
                                        <small>@item.TransactionDatesCsv</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No dates</span>
                                    }
                                </td>

                                <td class="text-center text-nowrap">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-info mb-1">
                                        Details
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-warning mb-1">
                                        Edit
                                    </a>
                                    @* <a asp-controller="SaleCharge" asp-action="Index" asp-route-saleId="@item.Id"
                                    class="btn btn-secondary btn-sm">
                                    Charges
                                    </a> 
                                    <a asp-controller="SaleTransactionDate" asp-action="Index"asp-route-saleId="@item.Id" 
                                    class="btn btn-primary btn-sm">
                                    Transactions
                                    </a> *@
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-danger mb-1">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>



@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        (() => {
            const statusBadge = document.getElementById("realtimeStatus");

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/sales")
                .withAutomaticReconnect()
                .build();

            const setStatus = (isConnected) => {
                if (!statusBadge) return;
                statusBadge.className = isConnected ? "badge text-bg-success ms-2" : "badge text-bg-warning ms-2";
                statusBadge.textContent = isConnected ? "Real-time: Connected" : "Real-time: Reconnecting";
            };

            connection.on("SalesUpdated", () => {
                window.location.reload();
            });

            connection.onreconnecting(() => setStatus(false));
            connection.onreconnected(() => setStatus(true));
            connection.onclose(() => setStatus(false));

            connection.start()
                .then(() => setStatus(true))
                .catch(() => setStatus(false));
        })();
    </script>
}

