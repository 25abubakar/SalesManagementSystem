@model IEnumerable<SalesManagementSystem.Models.SaleAcct>

@{
    ViewData["Title"] = "Sales List";
}

<div class="container mt-4">
    <h2 class="text-center">Sales Management</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">Add New Sale</a>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Platform</th>
                <th>Product</th>
                <th>Order ID</th>
                <th>Qty Sold</th>
                <th>Sold Amount</th>
                <th>From Account</th>
                <th>To Account</th>
                <th>Cost</th>
                <th>Profit</th>
                <th>Status</th>
                <th>Charges</th>
                <th>Transactions</th>
                <th width="310">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Platform?.PlatformName</td>
                    <td>@item.Product?.ProductName</td>
                    <td>@item.OrderID</td>
                    <td>@item.QtySold</td>
                    <td>@item.SoldAmount</td>
                    <td>@item.FromAccountId</td>
                    <td>@item.ToAccountId</td>
                    <td>@item.CostAmount</td>
                    <td class="text-success fw-bold">@item.ProfitAmount</td>
                    <td>@(item.StatusMaster?.StatusName ?? item.Status)</td>
                    <td>@(item.Charges?.Count ?? 0)</td>
                    <td>
                        @if (item.SaleTransactionDates != null && item.SaleTransactionDates.Any())
                        {
                            @string.Join(", ", item.SaleTransactionDates
                                .Where(x => x.SaleDate != null)
                                .Select(x => x.SaleDate!.DateLabel + ": " + x.Date.ToString("yyyy-MM-dd")))
                        }
                        else
                        {
                            <span class="text-muted">No dates</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        @* <a asp-controller="SaleCharge" asp-action="Index" asp-route-saleId="@item.Id" class="btn btn-secondary btn-sm">Charges</a> *@
                        @* <a asp-controller="SaleTransactionDate" asp-action="Index" asp-route-saleId="@item.Id" class="btn btn-primary btn-sm">Transactions</a> *@
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>