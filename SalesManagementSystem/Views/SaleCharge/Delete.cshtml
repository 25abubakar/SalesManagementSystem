@model SalesManagementSystem.Models.SaleCharge

@{
    ViewData["Title"] = "Delete Charge";
}

<div class="container mt-4">
    <h2>Delete Charge</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete this charge?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Sale</dt>
        <dd class="col-sm-9">@((Model.Sale?.OrderID ?? ("Sale#" + Model.SaleId)))</dd>

        <dt class="col-sm-3">Charge Type</dt>
        <dd class="col-sm-9">@Model.ChargeType?.ChargeTypeName</dd>

        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">@Model.Amount</dd>

        <dt class="col-sm-3">Remarks</dt>
        <dd class="col-sm-9">@Model.Remarks</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.SaleChargeId" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="SaleAcct" asp-action="Edit" asp-route-id="@Model.SaleId" class="btn btn-secondary">Cancel</a>
    </form>
</div>

