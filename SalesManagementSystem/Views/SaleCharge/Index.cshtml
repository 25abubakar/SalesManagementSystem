@model IEnumerable<SalesManagementSystem.Models.SaleCharge>

@{
    ViewData["Title"] = "Sale Charges";
    long? saleId = ViewBag.SaleId;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Sale Charges</h2>
        <a asp-action="Create" asp-route-saleId="@saleId" class="btn btn-primary">Add Charge</a>
    </div>

    @if (saleId != null)
    {
        <div class="alert alert-info">
            Showing charges for SaleId: <strong>@saleId</strong>
            <a asp-action="Index" class="ms-2">Show all</a>
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Sale</th>
                <th>Charge Type</th>
                <th>Amount</th>
                <th>Remarks</th>
                <th style="width: 220px;">Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SaleChargeId</td>
                <td>@(item.Sale?.OrderID ?? ("Sale#" + item.SaleId))</td>
                <td>@item.ChargeType?.ChargeTypeName</td>
                <td>@item.Amount</td>
                <td>@item.Remarks</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.SaleChargeId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.SaleChargeId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.SaleChargeId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

