@model SalesManagementSystem.Models.DashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
    var maxValue = Model.MonthlySales.Any()
        ? Model.MonthlySales.Max(x => Math.Max(x.SoldAmount, x.ProfitAmount))
        : 0m;
}

<div class="dashboard-page">
    <div class="hero-section text-center mb-4">
        <h1 class="fw-bold">Sales Management Dashboard</h1>
        <p class="mb-0">Total sales, profit, and recent activity in one clean workspace.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted">Total Sales</div>
                            <div class="metric-value">@Model.TotalSales.ToString("N0", CultureInfo.InvariantCulture)</div>
                        </div>
                        <div class="icon-circle bg-sales"><i class="bi bi-cart-check"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted">Total Sale Amount</div>
                            <div class="metric-value">@Model.TotalSoldAmount.ToString("N2", CultureInfo.InvariantCulture)</div>
                        </div>
                        <div class="icon-circle bg-sales"><i class="bi bi-cash-stack"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted">Total Profit</div>
                            <div class="metric-value">@Model.TotalProfitAmount.ToString("N2", CultureInfo.InvariantCulture)</div>
                        </div>
                        <div class="icon-circle bg-profit"><i class="bi bi-graph-up-arrow"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted">Average Profit</div>
                            <div class="metric-value">@Model.AverageProfitAmount.ToString("N2", CultureInfo.InvariantCulture)</div>
                        </div>
                        <div class="icon-circle bg-average"><i class="bi bi-bar-chart"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card dashboard-card h-100">
                <div class="card-body p-4 dashboard-chart-area">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold mb-0">Monthly Sales / Profit</h4>
                        <div class="chart-legend">
                            <span><span class="legend-dot" style="background:#0d6efd;"></span>Sales</span>
                            <span><span class="legend-dot" style="background:#198754;"></span>Profit</span>
                        </div>
                    </div>

                    @if (Model.MonthlySales.Any())
                    {
                        @foreach (var item in Model.MonthlySales)
                        {
                            var salesWidth = maxValue == 0 ? 0 : (item.SoldAmount / maxValue) * 100;
                            var profitWidth = maxValue == 0 ? 0 : (item.ProfitAmount / maxValue) * 100;
                            <div class="chart-row">
                                <div class="text-muted small">@item.Label</div>
                                <div class="chart-bars">
                                    <div class="chart-bar sales" style="width:@salesWidth.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                                    <div class="chart-bar profit" style="width:@profitWidth.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted">No monthly data available to render chart.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card dashboard-card h-100">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">Quick Actions</h4>
                    <div class="d-grid gap-3">
                        <a asp-controller="SaleAcct" asp-action="Index" class="btn btn-primary btn-dashboard">Open Sales</a>
                        <a asp-controller="SaleCharge" asp-action="Index" class="btn btn-success btn-dashboard">Open Charges</a>
                        <div class="dropdown">
                            <button class="btn btn-warning text-white btn-dashboard dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Open Masters
                            </button>
                            <ul class="dropdown-menu w-100">
                                <li><a class="dropdown-item" asp-controller="SalePlatform" asp-action="Index">Platform</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleProduct" asp-action="Index">Product</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleAccount" asp-action="Index">Account</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleStatus" asp-action="Index">Status</a></li>
                                <li><a class="dropdown-item" asp-controller="SaleTransactionType" asp-action="Index">Transaction Type</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card dashboard-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Recent Sales</h4>
                <a asp-controller="SaleAcct" asp-action="Index" class="btn btn-outline-primary btn-sm">View All</a>
            </div>
            <div class="table-responsive dashboard-table-wrap">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order ID</th>
                            <th>Platform</th>
                            <th>Product</th>
                            <th>Sale</th>
                            <th>Profit</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentSales.Any())
                        {
                            @foreach (var sale in Model.RecentSales)
                            {
                                <tr>
                                    <td>@sale.OrderID</td>
                                    <td>@sale.Platform?.PlatformName</td>
                                    <td>@sale.Product?.ProductName</td>
                                    <td>@sale.SoldAmount?.ToString("N2", CultureInfo.InvariantCulture)</td>
                                    <td class="fw-bold text-success">@sale.ProfitAmount?.ToString("N2", CultureInfo.InvariantCulture)</td>
                                    <td>@(sale.StatusMaster?.StatusName ?? sale.Status)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">No recent sales found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        (() => {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/sales")
                .withAutomaticReconnect()
                .build();

            connection.on("SalesUpdated", () => {
                window.location.reload();
            });

            connection.start().catch(() => {
            });
        })();
    </script>
}