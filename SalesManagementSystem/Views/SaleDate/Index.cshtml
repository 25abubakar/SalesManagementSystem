@model IEnumerable<SalesManagementSystem.Models.SaleDate>

@{
    ViewData["Title"] = "Sale Dates";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📅 Sale Dates</h3>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Trans Date</th>
                        <th>Process Date</th>
                        <th>Order Date</th>
                        <th>Sold Date</th>
                        <th>Payment Date</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.TransDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.ProcessDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.SoldDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.PaymentDate.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                No records found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>