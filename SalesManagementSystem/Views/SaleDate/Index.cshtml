@model IEnumerable<SalesManagementSystem.Models.SaleDate>

@{
    ViewData["Title"] = "Sale Dates";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📅 Sale Dates</h3>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Trans Date</th>
                        <th>Process Date</th>
                        <th>Order Date</th>
                        <th>Sold Date</th>
                        <th>Payment Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.SaleDateId</td>
                                <td>@item.TransDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.ProcessDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.OrderDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.SoldDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.PaymentDate?.ToString("yyyy-MM-dd HH:mm")</td>

                                <td class="text-center">

                                    <a asp-action="Edit" asp-route-id="@item.SaleDateId"
                                           class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.SaleDateId"
                                           class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                No records found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>