@model SalesManagementSystem.Models.SaleDate
@{
    ViewData["Title"] = "Edit Date Label";
}

<div class="container mt-5">

    <div class="card shadow-sm p-4">
        <h3 class="mb-3 text-warning">Edit Date Label</h3>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="DateLabel" class="form-label"></label>
                <input asp-for="DateLabel" class="form-control" />
                <span asp-validation-for="DateLabel" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-secondary">Back</a>
                <button type="submit" class="btn btn-success">Update</button>
            </div>
        </form>

    </div>
</div>