@model SalesManagementSystem.Models.SaleDate

@{
    ViewData["Title"] = "Create Sale Date";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<style>
    body {
        background: #f5f7fb;
    }

    .page-header {
        background: linear-gradient(135deg,#0d6efd,#4e73df);
        color: white;
        padding: 30px;
        border-radius: 16px;
        margin-bottom: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .card-section {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 22px rgba(0,0,0,0.06);
        padding: 25px;
        transition: .2s;
    }

        .card-section:hover {
            transform: translateY(-2px);
        }

    .section-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        margin-bottom: 18px;
        color: #0d6efd;
    }

    label {
        font-weight: 600;
        font-size: 13px;
        color: #555;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
    }

    .sticky-actions {
        position: sticky;
        bottom: 20px;
        background: rgba(255,255,255,0.95);
        padding: 15px;
        border-radius: 14px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn {
        border-radius: 10px;
        padding: 8px 18px;
        font-weight: 600;
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="page-header text-center">
        <h2><i class="bi bi-calendar-plus"></i> Create Sale Date</h2>
        <p class="mb-0">Auto or manual entry of sale timeline dates</p>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- DATES -->
        <div class="card-section">

            <div class="section-title">
                <i class="bi bi-calendar-event"></i> Sale Dates
            </div>

            <div class="row g-3">

                <div class="col-md-4">
                    <label>Transaction Date</label>
                    <input asp-for="TransDate" type="datetime" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label>Process Date</label>
                    <input asp-for="ProcessDate" type="datetime" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label>Order Date</label>
                    <input asp-for="OrderDate" type="datetime" class="form-control" />
                </div>

                <div class="col-md-6 mt-3">
                    <label>Sold Date</label>
                    <input asp-for="SoldDate" type="datetime" class="form-control" />
                </div>

                <div class="col-md-6 mt-3">
                    <label>Payment Date</label>
                    <input asp-for="PaymentDate" type="datetime" class="form-control" />
                </div>

            </div>
        </div>

        <!-- ACTIONS -->
        <div class="sticky-actions mt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Save
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    document.querySelectorAll('input[type="datetime"]').forEach(x => {
        x.addEventListener('change', function () {
            if (this.value) {
                let date = new Date(this.value);

                date.setHours(date.getHours());

                this.value = date.toISOString().slice(0,16);
            }
        });
    });
</script>
<script>
    flatpickr("input[type=datetime]", {
    enableTime: false, 
    dateFormat: "Y-m-d"
    });
</script>