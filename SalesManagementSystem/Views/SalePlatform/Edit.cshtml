@model SalesManagementSystem.Models.SalePlatform

@{
    ViewData["Title"] = "Edit Platform";
}

<div class="container mt-4">
    <h2>Edit Platform</h2>

    <form asp-action="Edit" asp-route-id="@Model.PlatformId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PlatformId" />

        <div class="row">
            <div class="col-md-6">
                <label class="form-label">Platform Name</label>
                <input asp-for="PlatformName" class="form-control" />
                <span asp-validation-for="PlatformName" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label class="form-label">CompanyId</label>
                <input asp-for="CompanyId" class="form-control" />
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label class="form-label">Is Active</label>
                <select asp-for="IsActive" class="form-select">
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-warning">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

