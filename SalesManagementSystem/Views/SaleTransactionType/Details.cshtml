@model SalesManagementSystem.Models.SaleTransactionType

@{
    ViewData["Title"] = "Transaction Type Details";
}

<div class="container mt-4">
    <h2>Transaction Type Details</h2>

    <dl class="row">
        <dt class="col-sm-3">Id</dt>
        <dd class="col-sm-9">@Model.TransactionId</dd>

        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.TransactionName</dd>

        <dt class="col-sm-3">Active</dt>
        <dd class="col-sm-9">@Model.IsActive</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.TransactionId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

